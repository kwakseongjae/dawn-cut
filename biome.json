{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignore": [
      "dist",
      "out",
      "vendor",
      "artifacts",
      "node_modules",
      "pkg",
      "fixtures",
      "test-results",
      "playwright-report"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off"
      },
      "a11y": {
        "useKeyWithClickEvents": "off",
        "useMediaCaption": "off"
      }
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "single", "trailingCommas": "all" }
  }
}
